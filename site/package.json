{
  "name": "folio-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/site-assets/style.css -o src/site-assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i src/site-assets/style.css -o src/site-assets/tailwind.css --watch",
    "build": "npm run build:css && npx @11ty/eleventy",
    "dev": "npx @11ty/eleventy --serve --port 8081"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "node-fetch": "^3.3.2",
    "tailwindcss": "^3.4.19"
  }
}
