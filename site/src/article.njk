---
pagination:
  data: articles.pages
  size: 1
  alias: item
permalink: "/{{ item.lang.code }}/articles/{{ item.article.slug }}.html"
---
{% extends "layouts/base.njk" %}

{% set lang = item.lang.code %}
{% set dir = item.lang.dir %}
{% set article = item.article %}

{% block title %}{{ article.meta_title or article.title }} · {{ site.name }}{% endblock %}
{% block description %}{{ article.meta_description or article.excerpt }}{% endblock %}

{% block content %}
{% set _articleSections = article_layout.byLang[lang] %}
{% if _articleSections | length %}
  {%- set _articleCtx = article -%}
  {% for block in _articleSections %}
    {% if block.type === "hero" %}
      {% set b = block %}
      {% include "partials/blocks/hero.njk" %}
    {% elif block.type === "featured-articles" %}
      {% set b = block %}
      {% include "partials/blocks/featured-articles.njk" %}
    {% elif block.type === "latest-articles" %}
      {% set b = block %}
      {% include "partials/blocks/latest-articles.njk" %}
    {% elif block.type === "cta-band" %}
      {% set b = block %}
      {% include "partials/blocks/cta-band.njk" %}
    {% elif block.type === "rich-text" %}
      {% set b = block %}
      {% include "partials/blocks/rich-text.njk" %}
    {% elif block.type === "image-text" %}
      {% set b = block %}
      {% include "partials/blocks/image-text.njk" %}
    {% elif block.type === "testimonials" %}
      {% set b = block %}
      {% include "partials/blocks/testimonials.njk" %}
    {% elif block.type === "newsletter" %}
      {% set b = block %}
      {% include "partials/blocks/newsletter.njk" %}
    {% elif block.type === "container" %}
      {% set b = block %}
      {% include "partials/blocks/container.njk" %}
    {% elif block.type === "text" %}
      {% set b = block %}
      {% include "partials/blocks/text.njk" %}
    {% elif block.type === "image" %}
      {% set b = block %}
      {% include "partials/blocks/image.njk" %}
    {% elif block.type === "button" %}
      {% set b = block %}
      {% include "partials/blocks/button.njk" %}
    {% elif block.type === "article-grid" %}
      {% set b = block %}
      {% include "partials/blocks/article-grid.njk" %}
    {% elif block.type === "article-card" %}
      {% set b = block %}
      {% include "partials/blocks/article-card.njk" %}
    {% elif block.type === "article-image" %}
      {% set b = block %}
      {% include "partials/blocks/article-image.njk" %}
    {% elif block.type === "article-title" %}
      {% set b = block %}
      {% include "partials/blocks/article-title.njk" %}
    {% elif block.type === "article-excerpt" %}
      {% set b = block %}
      {% include "partials/blocks/article-excerpt.njk" %}
    {% elif block.type === "article-date" %}
      {% set b = block %}
      {% include "partials/blocks/article-date.njk" %}
    {% elif block.type === "article-tag" %}
      {% set b = block %}
      {% include "partials/blocks/article-tag.njk" %}
    {% elif block.type === "article-body" %}
      {% set b = block %}
      {% include "partials/blocks/article-body.njk" %}
    {% endif %}
  {% endfor %}
{% else %}
<div class="max-w-3xl mx-auto px-6 py-12">
  <!-- Breadcrumb -->
  <nav class="text-xs mb-8" style="color: var(--color-muted);">
    <a href="/{{ lang }}/" style="color: var(--color-muted);">{{ i18n[lang].article_home }}</a>
    <span class="mx-2">›</span>
    <a href="/{{ lang }}/articles/" style="color: var(--color-muted);">{{ i18n[lang].articles_title }}</a>
    <span class="mx-2">›</span>
    <span style="color: var(--color-text);">{{ article.title }}</span>
  </nav>

  <!-- Cover image -->
  {% if article.cover_image_path %}
    <img
      id="article-cover"
      src="/uploads/{{ article.cover_image_path }}"
      alt="{{ article.title }}"
      class="w-full rounded-xl object-cover mb-10"
      style="max-height: 420px;"
    />
  {% endif %}

  <!-- Tag -->
  {% if article.tag %}
    <span class="inline-block text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4"
          style="background: color-mix(in srgb, var(--color-accent, #1a56db) 10%, transparent); color: var(--color-accent, #1a56db);">
      {{ article.tag }}
    </span>
  {% endif %}

  <!-- Title -->
  <h1 class="text-4xl font-extrabold leading-tight mb-4" style="color: var(--color-text);">{{ article.title }}</h1>

  <!-- Meta row -->
  <div class="flex items-center gap-4 text-sm mb-10 pb-6" style="color: var(--color-muted); border-bottom: 1px solid var(--color-border);">
    <time datetime="{{ article.published_at }}">{{ article.published_at | localizedDate(lang) }}</time>
    <span>·</span>
    <span>{{ article.body | readingTime(lang, i18n[lang].reading_time_suffix) }}</span>
  </div>

  <!-- Body -->
  <div class="prose max-w-none">
    {{ article.body | safe }}
  </div>

  <!-- Back link -->
  <div class="mt-16 pt-6 border-t">
    <a href="/{{ lang }}/articles/" class="text-sm font-medium" style="color: var(--color-accent, #1a56db);">
      ← {{ i18n[lang].article_back }}
    </a>
  </div>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
<script src="/site-assets/gallery.js" defer></script>
{% endblock %}
