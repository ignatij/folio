{% set items = b.config.items if b.config.items and b.config.items.length else [] %}
{%- if _inContainer -%}
<div class="w-full"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
{%- else -%}
<section class="reference-section fade-section always-visible space-y-10"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
{%- endif -%}
  <div class="space-y-2">
    <p class="reference-eyebrow">{{ b.config.eyebrow or "Gallery" }}</p>
    <h2 class="reference-section-title">{{ b.config.title or "In Focus" }}</h2>
  </div>
  <div class="grid gap-6 md:grid-cols-3">
    {% for item in items %}
      <button type="button" class="reference-gallery-card group" data-gallery-src="{{ item.src }}" aria-label="{{ item.alt or 'Open gallery image' }}">
        {% if item.src %}
          <img src="{{ item.src }}" alt="{{ item.alt or 'Piano performance still' }}" class="reference-gallery-image" loading="lazy" />
        {% endif %}
      </button>
    {% endfor %}
  </div>
{%- if _inContainer -%}</div>{%- else -%}</section>{%- endif -%}
