{% set latestArticles = articles.byLang[lang] | list %}
{% if latestArticles | length %}
{%- if _inContainer -%}<div class="w-full"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>{%- else -%}<section class="max-w-6xl mx-auto px-6 py-12 md:py-16"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>{%- endif -%}
  <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="blog-kicker">From the archive</p>
      <h2 class="blog-section-title font-semibold" style="color: var(--color-text);">{{ b.config.title | default("Recent Posts") }}</h2>
    </div>
    <a href="/{{ lang }}/articles/" class="blog-secondary-link text-sm">View all</a>
  </div>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {% for article in latestArticles | limit(b.config.max_count | default(6)) %}
      {% set article = article %}
      {% include "partials/article-card.njk" %}
    {% endfor %}
  </div>
{%- if _inContainer -%}</div>{%- else -%}</section>{%- endif -%}
{% endif %}
