{% set featuredArticles = articles.byLang[lang] | selectattr("is_featured") | list %}
{% if featuredArticles | length %}
<section class="max-w-6xl mx-auto px-6 py-12 md:py-16"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
  <div class="mb-8">
    <p class="blog-kicker">Featured</p>
    <h2 class="blog-section-title font-semibold" style="color: var(--color-text);">{{ b.config.title | default("Featured Essays") }}</h2>
  </div>
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {% for article in featuredArticles | limit(b.config.max_count | default(4)) %}
      {% set article = article %}
      {% include "partials/article-card.njk" %}
    {% endfor %}
  </div>
</section>
{% endif %}
