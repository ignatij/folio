{%- if _inContainer -%}
<div class="prose prose-neutral max-w-none w-full"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %} style="color: var(--color-text);{{ (' ' + b.config.customStyle) if b.config.customStyle else '' }}">
  {{ b.config.content | safe }}
</div>
{%- else -%}
<section class="max-w-5xl mx-auto px-6 py-10"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %} style="color: var(--color-text);{{ (' ' + b.config.customStyle) if b.config.customStyle else '' }}">
  <div class="prose prose-neutral max-w-none">
    {{ b.config.content | safe }}
  </div>
</section>
{%- endif -%}
