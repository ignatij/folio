{%- set cc = b.config -%}

{%- set tag = "p" -%}
{%- if cc.tag === "h1" or cc.tag === "h2" or cc.tag === "h3" or cc.tag === "h4" or cc.tag === "span" or cc.tag === "code" or cc.tag === "time" -%}
  {%- set tag = cc.tag -%}
{%- endif -%}

{# Build Tailwind class list #}
{%- set _cls = [] -%}
{%- set _dynStyle = "" -%}

{# Font size: explicit px OR tag-based heading class #}
{%- if cc.fontSize -%}
  {%- set _dynStyle = _dynStyle + "font-size:" + cc.fontSize + "px;" -%}
{%- elif tag === "h1" -%}{%- set _cls = (_cls.push("text-4xl"), _cls) -%}
{%- elif tag === "h2" -%}{%- set _cls = (_cls.push("text-3xl"), _cls) -%}
{%- elif tag === "h3" -%}{%- set _cls = (_cls.push("text-2xl"), _cls) -%}
{%- elif tag === "h4" -%}{%- set _cls = (_cls.push("text-xl"), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("text-base"), _cls) -%}
{%- endif -%}

{# Font weight #}
{%- if cc.fontWeight === "bold" -%}{%- set _cls = (_cls.push("font-bold"), _cls) -%}
{%- elif cc.fontWeight === "semibold" -%}{%- set _cls = (_cls.push("font-semibold"), _cls) -%}
{%- elif cc.fontWeight === "medium" -%}{%- set _cls = (_cls.push("font-medium"), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("font-normal"), _cls) -%}
{%- endif -%}

{# Text align #}
{%- if cc.textAlign === "center" -%}{%- set _cls = (_cls.push("text-center"), _cls) -%}
{%- elif cc.textAlign === "right" -%}{%- set _cls = (_cls.push("text-right"), _cls) -%}
{%- elif cc.textAlign === "justify" -%}{%- set _cls = (_cls.push("text-justify"), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("text-left"), _cls) -%}
{%- endif -%}

{# Italic #}
{%- if cc.italic -%}{%- set _cls = (_cls.push("italic"), _cls) -%}{%- endif -%}

{# Text color #}
{%- if cc.color -%}{%- set _dynStyle = _dynStyle + "color:" + cc.color + ";" -%}{%- endif -%}

{# Letter spacing — stored as hundredths of em (e.g. 50 → 0.5em) #}
{%- set _lts = cc.letterSpacing if cc.letterSpacing else 0 -%}
{%- if _lts -%}{%- set _dynStyle = _dynStyle + "letter-spacing:" + (_lts / 100) + "em;" -%}{%- endif -%}

{# Line height #}
{%- if cc.lineHeight -%}{%- set _dynStyle = _dynStyle + "line-height:" + cc.lineHeight + ";" -%}{%- endif -%}

{# Text transform #}
{%- if cc.textTransform === "uppercase" -%}{%- set _cls = (_cls.push("uppercase"), _cls) -%}
{%- elif cc.textTransform === "lowercase" -%}{%- set _cls = (_cls.push("lowercase"), _cls) -%}
{%- elif cc.textTransform === "capitalize" -%}{%- set _cls = (_cls.push("capitalize"), _cls) -%}
{%- endif -%}

{# Text decoration #}
{%- if cc.textDecoration === "underline" -%}{%- set _cls = (_cls.push("underline"), _cls) -%}
{%- elif cc.textDecoration === "line-through" -%}{%- set _cls = (_cls.push("line-through"), _cls) -%}
{%- endif -%}

{# Background color #}
{%- if cc.bgColor -%}{%- set _dynStyle = _dynStyle + "background-color:" + cc.bgColor + ";" -%}{%- endif -%}

{# Max width / min height — stored as CSS values, set as inline styles #}
{%- if cc.maxWidth -%}{%- set _dynStyle = _dynStyle + "max-width:" + cc.maxWidth + ";" -%}{%- endif -%}
{%- if cc.minHeight and cc.minHeight > 0 -%}{%- set _dynStyle = _dynStyle + "min-height:" + cc.minHeight + "px;" -%}{%- endif -%}

{# Padding (always >= 0) — concatenate with stored value directly #}
{%- set _cls = (_cls.push("pt-" + (cc.paddingTop if cc.paddingTop else 0)), _cls) -%}
{%- set _cls = (_cls.push("pb-" + (cc.paddingBottom if cc.paddingBottom else 0)), _cls) -%}
{%- set _cls = (_cls.push("pl-" + (cc.paddingLeft if cc.paddingLeft else 0)), _cls) -%}
{%- set _cls = (_cls.push("pr-" + (cc.paddingRight if cc.paddingRight else 0)), _cls) -%}

{# Margin — may be negative; negative integers require the "-mt-N" prefix form #}
{%- set _mt = cc.marginTop if cc.marginTop else 0 -%}
{%- if _mt is number and _mt < 0 -%}{%- set _cls = (_cls.push("-mt-" + (_mt | abs)), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("mt-" + _mt), _cls) -%}{%- endif -%}
{%- set _mb = cc.marginBottom if cc.marginBottom else 0 -%}
{%- if _mb is number and _mb < 0 -%}{%- set _cls = (_cls.push("-mb-" + (_mb | abs)), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("mb-" + _mb), _cls) -%}{%- endif -%}
{%- set _ml = cc.marginLeft if cc.marginLeft else 0 -%}
{%- if _ml is number and _ml < 0 -%}{%- set _cls = (_cls.push("-ml-" + (_ml | abs)), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("ml-" + _ml), _cls) -%}{%- endif -%}
{%- set _mr = cc.marginRight if cc.marginRight else 0 -%}
{%- if _mr is number and _mr < 0 -%}{%- set _cls = (_cls.push("-mr-" + (_mr | abs)), _cls) -%}
{%- else -%}{%- set _cls = (_cls.push("mr-" + _mr), _cls) -%}{%- endif -%}

{# Animation #}
{%- set _animStyle = "" -%}
{%- if cc.animation and cc.animation !== "none" -%}
  {%- set _cls = (_cls.push("anim-child"), _cls) -%}
  {%- set _cls = (_cls.push("animate-" + cc.animation), _cls) -%}
  {%- set _animStyle = "--anim-duration:" + (cc.animDuration if cc.animDuration else 600) + "ms;--anim-easing:" + (cc.animEasing if cc.animEasing else "ease-out") + ";--anim-delay:" + (cc.animDelay if cc.animDelay else 0) + "ms;" -%}
{%- endif -%}

<{{ tag }}{% if cc.elementId %} id="{{ cc.elementId }}"{% endif %} class="{{ _cls | join(' ') }}"{% if cc.customStyle or _animStyle or _dynStyle %} style="{{ _animStyle }}{{ _dynStyle }}{{ cc.customStyle }}"{% endif %}{% if cc.animation and cc.animation !== "none" %} data-anim-trigger="{{ cc.animTrigger if cc.animTrigger else 'scroll' }}" data-anim-once="{{ 'false' if cc.animOnce === false else 'true' }}"{% endif %}>{{ cc.content | safe }}</{{ tag }}>
