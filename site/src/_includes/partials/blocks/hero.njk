{%- set heroImage = b.config.bg_image or "/site-assets/reference/hero.jpg" -%}
{%- set heroTitle = b.config.headline or site.name -%}
{%- set heroSubtitle = b.config.subheadline or site.tagline -%}
{%- set heroNav = nav.byLang[lang] if nav.byLang and nav.byLang[lang] and nav.byLang[lang].length else [
  { label: "ABOUT", url: "#about", type: "external" },
  { label: "SCHEDULE", url: "#schedule", type: "external" },
  { label: "GALLERY", url: "#gallery", type: "external" },
  { label: "RECORDINGS", url: "#recordings", type: "external" }
] -%}

<section class="reference-hero relative min-h-screen overflow-hidden bg-black text-white"
  {% if b.config.elementId %}id="{{ b.config.elementId }}"{% endif %}
  {% if b.config.customStyle %}style="{{ b.config.customStyle }}"{% endif %}>
  <img
    src="{{ heroImage }}"
    alt="{{ heroTitle }}"
    class="absolute inset-0 h-full w-full object-cover object-top"
    loading="eager"
  />
  <div class="absolute inset-0 reference-hero-overlay"></div>

  <div class="relative z-10 flex min-h-screen flex-col">
    <nav class="flex flex-wrap items-center justify-between gap-6 px-6 py-6 text-xs uppercase sm:px-12">
      <a href="/{{ lang }}/" class="reference-brand">
        {{ heroTitle | upper }}
      </a>
      <div class="flex flex-wrap gap-4 sm:ml-auto sm:flex-nowrap sm:gap-9">
        {% for link in heroNav %}
          {% if link.type === "builtin" or link.type === "page" %}
            <a href="/{{ lang }}{{ link.url }}" class="reference-nav-link">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
          {% else %}
            <a href="{{ link.url }}" class="reference-nav-link">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
          {% endif %}
        {% endfor %}
      </div>
      <a href="#contact" class="reference-contact-link">Contact</a>
    </nav>

    <div class="flex flex-1 items-end px-6 pb-20 sm:px-12">
      <div class="max-w-3xl space-y-5">
        <div class="hero-line delay-2 h-px w-20 bg-white/70"></div>
        {% if heroSubtitle %}
          <p class="hero-line delay-3 reference-hero-subtitle">
            {{ heroSubtitle }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
