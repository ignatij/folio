{% set items = b.config.items if b.config.items and b.config.items.length else [] %}
{%- if _inContainer -%}
<div class="w-full"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
{%- else -%}
<section class="reference-section fade-section space-y-10"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
{%- endif -%}
  <div class="space-y-2">
    <p class="reference-eyebrow">{{ b.config.eyebrow or "Recordings" }}</p>
    <h2 class="reference-section-title">{{ b.config.title or "Watch & Listen" }}</h2>
  </div>
  <div class="grid gap-6 lg:grid-cols-2">
    {% for item in items %}
      <div class="space-y-3 rounded-[28px] border bg-white/80 p-4 shadow-sm" style="border-color:#cec6bb;">
        <div class="aspect-video overflow-hidden rounded-2xl">
          {% if item.src %}
            <iframe
              src="{{ item.src }}"
              title="{{ item.title or 'Recording' }}"
              width="100%"
              height="100%"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="h-full w-full"
              style="border:0;"
            ></iframe>
          {% endif %}
        </div>
        <p class="reference-card-title">{{ item.title }}</p>
      </div>
    {% endfor %}
  </div>
{%- if _inContainer -%}</div>{%- else -%}</section>{%- endif -%}
