{% set items = b.config.items if b.config.items and b.config.items.length else [] %}
{%- if _inContainer -%}
<div class="w-full"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
{%- else -%}
<section class="reference-section fade-section space-y-10"{% if b.config.elementId %} id="{{ b.config.elementId }}"{% endif %}{% if b.config.customStyle %} style="{{ b.config.customStyle }}"{% endif %}>
{%- endif -%}
  <div class="space-y-2">
    <p class="reference-eyebrow">{{ b.config.eyebrow or "Schedule" }}</p>
    <h2 class="reference-section-title">{{ b.config.title or "Upcoming Performances" }}</h2>
  </div>
  <div class="reference-schedule-list">
    {% for item in items %}
      <div class="reference-schedule-row">
        <div class="reference-schedule-date">{{ item.date }}</div>
        <div class="flex-1">
          <p class="reference-schedule-title">{{ item.title | escape | replace("&amp;", "<span class=\"ampersand\">&amp;</span>") | safe }}</p>
        </div>
        <div class="reference-schedule-meta">
          <p class="reference-schedule-location">{{ item.location }}</p>
          {% if item.detailUrl %}
            <a class="reference-schedule-detail" href="{{ item.detailUrl }}">Details</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
{%- if _inContainer -%}</div>{%- else -%}</section>{%- endif -%}
